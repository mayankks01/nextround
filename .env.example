# Used only by server/index.js (the optional local API proxy).
# Set only one provider key at a time.
ANTHROPIC_API_KEY=

# Hugging Face Inference API (free tier available).
# Get a token from https://huggingface.co/settings/tokens
# Pick a chat model supported by the Hugging Face router.
# Example: deepseek-ai/DeepSeek-R1:fastest
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=deepseek-ai/DeepSeek-R1:fastest

# OAuth (optional — for real Google / GitHub sign-in)
# Create OAuth credentials and set these values. Redirect URIs should include:
#  - http://localhost:3001/auth/google/callback
#  - http://localhost:3001/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
